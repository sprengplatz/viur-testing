{
  "name": "@spltz/viur-testing",
  "version": "0.1.1",
  "description": "Playwright fixtures, global setup/teardown, helpers and a Vite plugin for projects driven by viur-testing.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./global-setup": {
      "types": "./dist/global-setup.d.ts",
      "import": "./dist/global-setup.js",
      "default": "./dist/global-setup.js"
    },
    "./global-teardown": {
      "types": "./dist/global-teardown.d.ts",
      "import": "./dist/global-teardown.js",
      "default": "./dist/global-teardown.js"
    }
  },
  "bin": {
    "viur-testing-init": "bin/init.mjs"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@playwright/test": "^1.49.0",
    "vite": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
